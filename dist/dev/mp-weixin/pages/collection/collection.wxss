  font-weight: bold;
}
.meta-row.data-v-f0d3a5d5 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}
.date-text.data-v-f0d3a5d5 {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.9);
  font-family: monospace;
}
