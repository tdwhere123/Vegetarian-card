
.container.data-v-f0d3a5d5 {
  padding: 30rpx;
  height: 100vh;
  background-color: #f7f1e3; /* Warm Beige */
  display: flex;
  flex-direction: column;
  padding-bottom: 120rpx; /* Space for TabBar */
}
.loading-state.data-v-f0d3a5d5, .empty-state.data-v-f0d3a5d5 {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 50vh;
}
.empty-text.data-v-f0d3a5d5 {
  font-size: 32rpx;
  color: #888;
  margin-bottom: 30rpx;
}
.create-btn.data-v-f0d3a5d5 {
  background: #ff6b6b;
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
}
.fade-in.data-v-f0d3a5d5 {
  animation: fadeIn-f0d3a5d5 0.6s cubic-bezier(0.25, 0.8, 0.25, 1);
}
@keyframes fadeIn-f0d3a5d5 {
from { opacity: 0; transform: scale(0.98) translateY(20rpx);
}
to { opacity: 1; transform: scale(1) translateY(0);
}
}
.header-bar.data-v-f0d3a5d5 {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 30rpx;
  padding: 0 10rpx;
  margin-top: 40rpx;
}
.title.data-v-f0d3a5d5 {
  font-size: 40rpx;
  font-weight: 900;
  color: #2c3e50;
  letter-spacing: 2rpx;
}
.stats.data-v-f0d3a5d5 {
  font-size: 24rpx;
  color: #7f8c8d;
}
.grid-scroll.data-v-f0d3a5d5 {
  flex: 1;
  height: 0;
}
.grid.data-v-f0d3a5d5 {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between; /* Ensure items spread out */
  padding-bottom: 40rpx;
}
.card-item.data-v-f0d3a5d5 {
  width: 48%; /* Force 2 columns with gap */
  aspect-ratio: 3/4;
  margin-bottom: 24rpx;
}
.card-border.data-v-f0d3a5d5 {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  padding: 8rpx;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.1);
  background: #fff;
  transition: transform 0.1s;
}
.card-border.data-v-f0d3a5d5:active {
  transform: scale(0.98);
}
.border-n.data-v-f0d3a5d5 { border: 2rpx solid #bdc3c7;
}
.border-r.data-v-f0d3a5d5 { border: 2rpx solid #3498db;
}
.border-sr.data-v-f0d3a5d5 { border: 2rpx solid #9b59b6;
}
.border-magic.data-v-f0d3a5d5 { border: 2rpx solid #e056fd; box-shadow: 0 0 16rpx rgba(156, 39, 176, 0.4); background: #2c0b3c;
}
.card-content.data-v-f0d3a5d5 {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
  background: #eee;
}
.image.data-v-f0d3a5d5 {
  width: 100%;
  height: 100%;
}
.rarity-tag.data-v-f0d3a5d5 {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 8rpx;
  font-weight: bold;
}
.tag-magic.data-v-f0d3a5d5 {
  background: rgba(156, 39, 176, 0.8);
  border: 1rpx solid #e056fd;
}
.card-footer.data-v-f0d3a5d5 {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
  padding: 20rpx 10rpx 10rpx;
}
.dish-name.data-v-f0d3a5d5 {
  color: #fff;
  font-size: 26rpx;
  font-weight: bold;
  display: block;
  white-space: nowrap;
  overflow: hidden;
