
.container.data-v-9cb6f745 {
  padding: 0;
  height: 100vh;
  background-color: #f7f3ea;
  perspective: 1500rpx; /* 3D Perspective */
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.scene.data-v-9cb6f745 {
  width: 600rpx;
  height: 900rpx;
  position: relative;
  margin-bottom: 40rpx;
}
.card.data-v-9cb6f745 {
  width: 100%;
  height: 100%;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.card.is-flipped.data-v-9cb6f745 {
  transform: rotateY(180deg);
}
.card-face.data-v-9cb6f745 {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.15);
}
.card-front.data-v-9cb6f745 {
  background: #fff;
}
.card-back.data-v-9cb6f745 {
  background: #fff;
  transform: rotateY(180deg);
  display: flex;
  flex-direction: column;
}

/* Back Styles */
.back-inner.data-v-9cb6f745 {
  padding: 30rpx;
  height: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  background: #fff9e6;
}
.back-header.data-v-9cb6f745 {
  font-size: 36rpx;
  font-weight: bold;
  color: #5d4037;
  text-align: center;
  margin-bottom: 20rpx;
}
.user-image.data-v-9cb6f745 {
  width: 100%;
  height: 400rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
}
.user-note-box.data-v-9cb6f745, .ai-comment-box.data-v-9cb6f745 {
  background: rgba(255,255,255,0.6);
  padding: 20rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}
.note-label.data-v-9cb6f745, .ai-label.data-v-9cb6f745 {
  font-weight: bold;
  color: #795548;
  display: block;
  margin-bottom: 8rpx;
}
.ai-content.data-v-9cb6f745 {
  color: #d81b60;
  font-style: italic;
}
.ai-loading.data-v-9cb6f745 {
  color: #888;
  font-size: 26rpx;
  display: flex;
  align-items: center;
}
.spin-small.data-v-9cb6f745 {
  animation: spin-9cb6f745 2s linear infinite;
  margin-right: 10rpx;
  display: inline-block;
}
.back-footer.data-v-9cb6f745 {
  margin-top: auto;
  text-align: center;
  font-size: 24rpx;
  color: #aaa;
}

/* Keep original inner styles mostly */
.card-inner.data-v-9cb6f745 {
  height: 100%;
  display: flex;
  flex-direction: column;
  background-color: #fff;
}
.rarity-badge.data-v-9cb6f745 {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: #000;
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: bold;
  font-size: 24rpx;
  z-index: 10;
}
.image-area.data-v-9cb6f745 {
  height: 420rpx; /* Fixed height instead of percentage */
  min-height: 420rpx;
  width: 100%;
  position: relative;
  flex-shrink: 0; /* Prevent compression */
}
.image-wrap.data-v-9cb6f745 {
  width: 100%;
  height: 100%;
  min-height: 420rpx;
  position: relative;
}
.grayscale.data-v-9cb6f745 {
  filter: grayscale(100%);
}
.image.data-v-9cb6f745 {
  width: 100%;
  height: 100%;
  display: block;
}
.generating-placeholder.data-v-9cb6f745 {
  width: 100%;
  height: 100%;
  min-height: 420rpx;
  background: #eee;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #888;
}
.spin.data-v-9cb6f745 {
  font-size: 60rpx;
  animation: spin-9cb6f745 2s linear infinite;
  margin-bottom: 20rpx;
}
@keyframes spin-9cb6f745 {
100% { transform: rotate(360deg);
}
}
.lock-overlay.data-v-9cb6f745 {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
}
.content-area.data-v-9cb6f745 {
  flex: 1;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
}
.header.data-v-9cb6f745 {
  text-align: center;
  margin-bottom: 20rpx;
}
.title.data-v-9cb6f745 {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}
.scroll-content.data-v-9cb6f745 {
  flex: 1;
  overflow-y: auto;
}
.section.data-v-9cb6f745 { margin-bottom: 30rpx;
}
.section-title.data-v-9cb6f745 {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 16rpx;
  text-align: center;
}
.chips.data-v-9cb6f745 { display: flex; flex-wrap: wrap; justify-content: center; gap: 10rpx;
}
.chip.data-v-9cb6f745 { background: #f0f0f0; padding: 6rpx 20rpx; border-radius: 30rpx; font-size: 24rpx;
}
.step-item.data-v-9cb6f745 { display: flex; margin-bottom: 16rpx;
}
.step-num.data-v-9cb6f745 { 
  background: #333; color: #fff; width: 36rpx; height: 36rpx; 
  border-radius: 50%; text-align: center; line-height: 36rpx; 
  font-size: 22rpx; margin-right: 16rpx; flex-shrink: 0;
}
.step-text.data-v-9cb6f745 { font-size: 28rpx; color: #555; line-height: 1.5;
}
.footer.data-v-9cb6f745 {
  position: absolute;
  bottom: 60rpx;
  width: 100%;
  display: flex;
  justify-content: center;
}
.btn.data-v-9cb6f745 {
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  box-shadow: 0 10rpx 20rpx rgba(0,0,0,0.1);
}
.btn-primary.data-v-9cb6f745 { background: #333; color: #fff;
}
.btn-success.data-v-9cb6f745 { background: #4caf50; color: #fff;
}
.btn-icon.data-v-9cb6f745 { margin-right: 10rpx;
}

/* Modal */
.modal-mask.data-v-9cb6f745 {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-content.data-v-9cb6f745 {
  background: #fff;
  width: 600rpx;
  padding: 40rpx;
  border-radius: 20rpx;
}
.modal-title.data-v-9cb6f745 {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}
.modal-input.data-v-9cb6f745 {
  width: 100%;
  height: 200rpx;
  background: #f9f9f9;
  padding: 20rpx;
  box-sizing: border-box;
  margin-bottom: 30rpx;
  border-radius: 10rpx;
}
.modal-actions.data-v-9cb6f745 {
  display: flex;
  justify-content: space-between;
}
.modal-btn.data-v-9cb6f745 {
  width: 45%;
  font-size: 28rpx;
}
.confirm.data-v-9cb6f745 { background: #333; color: #fff;
}
.legal-tip.data-v-9cb6f745 {
  position: absolute;
  bottom: 10rpx;
  width: 100%;
  text-align: center;
  font-size: 22rpx;
  color: #9e9e9e;
}
.loading-container.data-v-9cb6f745 {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
}
.magic-circle.data-v-9cb6f745 { font-size: 80rpx; animation: spin-9cb6f745 3s linear infinite; margin-bottom: 40rpx;
}
.loading-text.data-v-9cb6f745 { font-size: 32rpx; color: #555; font-weight: bold; margin-bottom: 20rpx;
}
.loading-tips.data-v-9cb6f745 { font-size: 24rpx; color: #999;
}

/* Magic Theme Styles */
.container.theme-magic.data-v-9cb6f745 {
  background-color: #2c0b3c;
  background-image: 
    radial-gradient(rgba(156, 39, 176, 0.2) 1px, transparent 1px),
    radial-gradient(rgba(156, 39, 176, 0.1) 1px, transparent 1px);
}
.theme-magic .loading-text.data-v-9cb6f745 { color: #e056fd; text-shadow: 0 0 10rpx rgba(224, 86, 253, 0.5);
}
.theme-magic .magic-circle.data-v-9cb6f745 { color: #e056fd; text-shadow: 0 0 20rpx rgba(224, 86, 253, 0.8);
}
.theme-magic .loading-tips.data-v-9cb6f745 { color: #d1c4e9;
}
.theme-magic .card-front.data-v-9cb6f745 {
  background: #1a1a2e;
  border: 2rpx solid #e056fd;
  box-shadow: 0 0 30rpx rgba(156, 39, 176, 0.3);
}
.theme-magic .card-inner.data-v-9cb6f745 { background-color: #1a1a2e;
}
.theme-magic .title.data-v-9cb6f745 { color: #e056fd; text-shadow: 0 0 10rpx rgba(224, 86, 253, 0.3);
}
.theme-magic .section-title.data-v-9cb6f745 { color: #ce93d8;
}
.theme-magic .chip.data-v-9cb6f745 { background: #4a148c; color: #e1bee7; border: 1rpx solid #7b1fa2;
}
.theme-magic .step-text.data-v-9cb6f745 { color: #e1bee7;
}
.theme-magic .step-num.data-v-9cb6f745 { background: #e056fd; color: #2c0b3c; box-shadow: 0 0 10rpx rgba(224, 86, 253, 0.5);
}
.theme-magic .generating-placeholder.data-v-9cb6f745 { background: #2c0b3c; color: #ce93d8;
}
.theme-magic .legal-tip.data-v-9cb6f745 { color: #ab47bc;
}
.theme-magic .card-back.data-v-9cb6f745 { background: #1a1a2e; border: 2rpx solid #e056fd;
}
.theme-magic .back-inner.data-v-9cb6f745 { background: #2c0b3c;
}
.theme-magic .back-header.data-v-9cb6f745 { color: #e056fd;
}
.theme-magic .user-note-box.data-v-9cb6f745, .theme-magic .ai-comment-box.data-v-9cb6f745 { background: rgba(74, 20, 140, 0.6); border: 1rpx solid #7b1fa2;
}
.theme-magic .note-label.data-v-9cb6f745, .theme-magic .ai-label.data-v-9cb6f745 { color: #e056fd;
}
.theme-magic .note-content.data-v-9cb6f745 { color: #e1bee7;
}
.theme-magic .ai-content.data-v-9cb6f745 { color: #f8bbd0;
}
.theme-magic .user-image.data-v-9cb6f745 { border-color: #e056fd;
}
.theme-magic .btn-primary.data-v-9cb6f745 { 
  background: linear-gradient(135deg, #7b1fa2, #e056fd); 
  box-shadow: 0 0 20rpx rgba(156, 39, 176, 0.5);
}
.theme-magic .btn-success.data-v-9cb6f745 {
  background: linear-gradient(135deg, #009688, #64ffda);
  color: #004d40;
}
